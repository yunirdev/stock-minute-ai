# Copy to .env and fill in your own values. .env is gitignored.

# Broker: alpaca_paper (paper account) | alpaca_live (real money)
# alpaca_paper must use Paper Trading keys from the Alpaca dashboard.
BROKER_TYPE=alpaca_paper

# Data feed: alpaca
DATA_FEED_TYPE=alpaca

# Alpaca API key/secret.
# Paper and live accounts have separate keys. Mixing them can cause 401 errors.
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_DATA_FEED=iex

# Optional: default universe for data download / warm-up scripts
SYMBOLS=SPY,QQQ,AAPL,MSFT,NVDA

# Market data database and trading audit database
DB_PATH=market.duckdb
TRADE_DB_PATH=trade.duckdb

# AI / LLM 配置
# LLM_PROVIDER: ollama(本地,免费) | anthropic(需API key) | stub(离线测试)
LLM_PROVIDER=ollama
# Ollama 本地端点（默认 localhost:11434，ollama pull llama3.2）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Anthropic（可选）：若 LLM_PROVIDER=anthropic 则需要
ANTHROPIC_API_KEY=

# Discord 推送 webhook（可选，留空则降级到 console 打印）
DISCORD_WEBHOOK_URL=
