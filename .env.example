# Copy to .env and fill in your own values. .env is gitignored — never commit secrets.

# Broker: local_paper = in-memory simulation, no external API (default)
BROKER_TYPE=local_paper

# Data feed: yfinance (free, no key) | alpaca (needs keys below)
DATA_FEED_TYPE=yfinance

# Alpaca market data (only needed if DATA_FEED_TYPE=alpaca or for full history download)
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_DATA_FEED=sip

# Optional: default universe for data download / warm-up scripts
SYMBOLS=SPY,QQQ,AAPL,MSFT,NVDA
